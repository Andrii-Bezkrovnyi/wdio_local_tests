{
  "name": "wdio_task",
  "type": "module",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@wdio/allure-reporter": "^9.27.2",
    "@wdio/cli": "^9.27.2",
    "@wdio/globals": "^9.27.2",
    "@wdio/local-runner": "^9.27.2",
    "@wdio/mocha-framework": "^9.27.2",
    "@wdio/spec-reporter": "^9.27.2",
    "allure-commandline": "^2.42.0",
    "prettier": "^3.8.3"
  },
  "scripts": {
    "wdio": "wdio run ./wdio.conf.js",
    "test:login": "wdio run ./wdio.conf.js --spec ./test/specs/login.spec.js",
    "test:checkout": "wdio run ./wdio.conf.js --spec ./test/specs/checkout.spec.js",
    "test:cart": "wdio run ./wdio.conf.js --spec ./test/specs/cart.spec.js",
    "test:footer": "wdio run ./wdio.conf.js --spec ./test/specs/footer.spec.js",
    "test:products": "wdio run ./wdio.conf.js --spec ./test/specs/products.spec.js",
    "download-driver": "node ./download-driver.js",
    "report": "allure generate allure-results --clean && allure open",
    "test:checker": "wdio run ./wdio.conf.js --spec ./test/specs/check.spec.js"
  }
}
